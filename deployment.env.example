# Optional one-off backend selector for direct Modal deployments.
# Normal deployments use `mn` or scripts/deploy-release.sh and set this safely.
MN_MODEL=god

# Available tracked profiles:
#   god  -> MN God, Qwen3.6 35B A3B, 1 x H200
#   code -> MN Code, Ornith 35B, 1 x H200
#   fast -> MN Fast, Qwythos 9B, 1 x L40S
#
# Model IDs, revisions, GPU limits, context sizes, parsers, and scale-to-zero
# controls are versioned in config/mn.json. Secrets never belong in this file.
