# Current open-weight SWE-bench leader's abliterated W4A16 derivative.
MODEL_NAME=cebeuq/Ornith-1.0-397B-abliterated-W4A16
MODEL_REVISION=e5651d291be1c65ff1360eee47ab533ab13b3d97
SERVED_MODEL_NAME=nuri/ornith-397b-abliterated

# The checkpoint occupies about 210 GB; two H200s provide 282 GB of VRAM.
GPU_TYPE=H200
GPU_COUNT=2
MAX_MODEL_LEN=32768
GPU_MEMORY_UTILIZATION=0.90

# Fast boot avoids compilation during early scale-to-zero testing.
FAST_BOOT=true
TRUST_REMOTE_CODE=true
QUANTIZATION=

# Optional. Leave blank for this public checkpoint, or set to a Modal secret name.
HF_SECRET_NAME=

# Cost controls. The deployed default is stopped. `mn start` and `mn stop`
# dynamically change the minimum container count and scaledown window.
MAX_CONTAINERS=1
SCALEDOWN_WINDOW_SECONDS=300
TARGET_CONCURRENCY=1
ROUTING_REGION=eu-west
