{
  "name": "abliterated-cloud-website",
  "private": true,
  "type": "module",
  "version": "0.6.0",
  "scripts": {
    "dev:website": "wrangler dev --config wrangler.jsonc --port 8788",
    "deploy:website:preview": "wrangler deploy --config wrangler.jsonc --env=",
    "deploy:website:production": "wrangler deploy --config wrangler.jsonc --env production",
    "verify:agent-ready": "node scripts/verify-agent-ready.mjs",
    "verify:agent-ready:local": "node scripts/verify-agent-ready.mjs http://localhost:8788 --local-only"
  },
  "devDependencies": {
    "wrangler": "^4.66.0"
  }
}
