{
  "openapi": "3.1.0",
  "info": {
    "title": "ABLITERATED.cloud API",
    "version": "0.3.1",
    "description": "Private, token-protected OpenAI-compatible Chat Completions access to exact pinned Hugging Face models. Live v0.3.1 currently exposes mn/god, mn/code, and mn/fast. mn/ornith-397b is prepared for the next budgeted release.",
