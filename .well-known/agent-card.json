{
  "name": "ABLITERATED.cloud Public Site Agent",
  "description": "Read-only discovery agent for the ABLITERATED.cloud model catalog, API documentation and operating status.",
  "url": "https://abliterated.cloud/a2a",
  "version": "1.0.0",
  "provider": {
    "organization": "ABLITERATED.cloud",
    "url": "https://abliterated.cloud"
  },
  "documentationUrl": "https://abliterated.cloud/llms-full.txt",
  "supportedInterfaces": [
    {
      "url": "https://abliterated.cloud/a2a",
      "protocolBinding": "https://a2aprotocol.ai/bindings/http-jsonrpc",
      "protocolVersion": "0.3"
    }
  ],
  "defaultInputModes": ["text/plain"],
  "defaultOutputModes": ["application/json", "text/plain"],
  "skills": [
    {
      "id": "model-catalog",
      "name": "Model catalog",
      "description": "Returns exact Hugging Face repositories, availability, hosting details and prices.",
      "tags": ["models", "hugging-face", "openai-compatible-api"]
    }
  ],
  "capabilities": {
    "streaming": false,
    "pushNotifications": false,
    "stateTransitionHistory": false
  },
  "authentication": {
    "schemes": ["none", "oauth2"]
  }
}
